# Caddy 리버스 프록시 설정 (운영 서버 전용).
#
# Caddy는 "경비실" 역할:
#  1) 바깥 손님을 80(http)/443(https) 문에서 받고
#  2) Let's Encrypt 무료 SSL 인증서를 자동 발급/갱신해 https(자물쇠)를 켜고
#  3) 요청을 컨테이너 네트워크 안의 web(3000)으로 넘긴다.
#
# 자물쇠 발급 조건: 도메인 A레코드가 이 서버 IP를 가리키고, 보안그룹에서 80/443이
# 열려 있어야 한다(둘 다 Stage 3 뒤에서 설정). 그 전엔 caddy가 발급을 계속 재시도한다.

# 전역 옵션: 인증서 만료 등 알림을 받을 이메일.
{
	email c0d3with.mj@gmail.com
}

# 이 도메인으로 오는 요청을 처리. caddy가 이 도메인의 인증서를 자동으로 발급한다.
ssakssak-commit.com {
	# 같은 compose 네트워크의 web 컨테이너로 전달 (서비스 이름 'web'으로 통신).
	reverse_proxy web:3000
}
