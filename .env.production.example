# ============================================================
# 운영(서버) 환경변수 템플릿
# ------------------------------------------------------------
# 사용법: 서버에서 이 파일을 .env.production 으로 복사 후 실제 값 채우기.
# ⚠️ 실제 값이 든 .env / .env.production 은 절대 커밋 금지 (.gitignore 확인).
# ============================================================

# ---------- 인증 (NextAuth + GitHub OAuth) ----------
# 운영 도메인. OAuth 콜백/세션이 이 주소 기준으로 동작 → 반드시 https 실제 도메인.
NEXTAUTH_URL=https://your-domain.com
# 세션 암호화 키. 생성: openssl rand -base64 32
NEXTAUTH_SECRET=

# Stage 2에서 새로 발급할 GitHub OAuth App 값.
# 콜백 URL = https://your-domain.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- 데이터베이스 (관리형: Supabase) ----------
# Supabase 대시보드 > Project Settings > Database > Connection string 에서 복사.
# 운영 서버는 Connection pooler(포트 6543, pgbouncer) 권장.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres

# ---------- Redis (compose의 redis 서비스) ----------
# 호스트는 서비스 이름 'redis'.
REDIS_URL=redis://redis:6379

# ---------- OpenAI ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
