# ============================================================
# 운영(서버) 환경변수 템플릿
# ------------------------------------------------------------
# 사용법: 서버에서 이 파일을 .env.production 으로 복사 후 실제 값 채우기.
# ⚠️ 실제 값이 든 .env / .env.production 은 절대 커밋 금지 (.gitignore 확인).
# ============================================================

# ---------- 인증 (NextAuth + GitHub OAuth) ----------
# 운영 도메인. OAuth 콜백/세션이 이 주소 기준으로 동작 → 반드시 https 실제 도메인.
NEXTAUTH_URL=https://your-domain.com
# 세션 암호화 키. 생성: openssl rand -base64 32
NEXTAUTH_SECRET=

# Stage 2에서 새로 발급할 GitHub OAuth App 값.
# 콜백 URL = https://your-domain.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- 데이터베이스 (관리형: Supabase) ----------
# Supabase 대시보드 > Connect > Session pooler 의 connection string 복사.
# 상주 컨테이너(web/worker)는 Session pooler(포트 5432) 사용 — Prisma 자체 풀+prepared
# statement 지원, prisma db push 정상. Transaction pooler(6543)는 서버리스용이라 부적합
# (?pgbouncer=true 강제+db push 불안정), Direct는 무료플랜 IPv6 전용이라 EC2(IPv4)서 불가.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres

# ---------- Redis (관리형: Upstash) ----------
# Upstash 콘솔 > 해당 DB > 연결 정보의 connection string 복사.
# ⚠️ TLS 필수 → redis:// 가 아니라 rediss:// (s 2개). ioredis가 자동으로 TLS 적용.
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# ---------- OpenAI ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
